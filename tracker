import discord
import sqlite3
from discord.ext import commands

# 1. Database Initialization
def init_db():
    conn = sqlite3.connect('rarity_data.db')
    c = conn.cursor()
    c.execute('''CREATE TABLE IF NOT EXISTS interactions 
                 (source TEXT, target TEXT, type TEXT, weight REAL, timestamp DATETIME DEFAULT CURRENT_TIMESTAMP)''')
    conn.commit()
    return conn

bot = commands.Bot(command_prefix="!", intents=discord.Intents.all())
db_conn = init_db()

@bot.event
async def on_ready():
    print(f'Tracker active as {bot.user}')

@bot.event
async def on_message(message):
    if message.author.bot: return
    
    # Log a standard message interaction
    cursor = db_conn.cursor()
    cursor.execute("INSERT INTO interactions (source, target, type, weight) VALUES (?, ?, ?, ?)",
                   (str(message.author.id), "SERVER", "MESSAGE", 1.0))
    db_conn.commit()
    print(f"📝 Logged message from {message.author.name}")
    await bot.process_commands(message)

@bot.event
async def on_voice_state_update(member, before, after):
    # Log when someone joins a VC
    if before.channel is None and after.channel is not None:
        cursor = db_conn.cursor()
        cursor.execute("INSERT INTO interactions (source, target, type, weight) VALUES (?, ?, ?, ?)",
                       (str(member.id), str(after.channel.id), "VC_JOIN", 5.0))
        db_conn.commit()
        print(f"🔊 Logged VC Join for {member.name}")

bot.run('YOUR_TOKEN')