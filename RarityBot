# Global cache to keep VC joins fast (O(1) lookup)
user_rarity_cache = {}

@tasks.loop(hours=1)
async def update_rarity_cache():
    """Background task to run the Linear Algebra once an hour."""
    global user_rarity_cache
    scores = calculate_pagerank()
    if not scores: return

    total = len(scores)
    new_cache = {}
    for i, (user_id, score) in enumerate(scores):
        percentile = i / total
        if percentile < 0.01: rarity = "Divine"
        elif percentile < 0.10: rarity = "Mythic"
        elif percentile < 0.25: rarity = "Legendary"
        else: rarity = "Common"
        new_cache[user_id] = rarity
    
    user_rarity_cache = new_cache
    print("✅ Rarity cache updated via PageRank.")

@bot.event
async def on_ready():
