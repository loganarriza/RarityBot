@bot.event
async def on_voice_state_update(member, before, after):
    """The 'Entry Frag' - Records interaction, joins VC, and plays random sound."""
    if member.bot: return

    # Only trigger when joining a channel (was not in one before)
    if before.channel is None and after.channel is not None:
        
        # --- LOCK LOGIC: Prevent '4006' Session Errors ---
        if member.id in processing_users:
            return 
        processing_users.add(member.id)
        # ------------------------------------------------

        try:
            # 1. TRACKING LOGIC: Record high-weight interaction in DB
            # Pointing to "SERVER" as the central hub for PageRank
            cursor.execute(
                "INSERT INTO interactions (source, target, type, weight) VALUES (?, ?, ?, ?)",
                (str(member.id), "SERVER", 'VC_JOIN', 5.0)
            )
            db.commit()
            print(f"📊 Recorded VC Join for {member.name}")

            # 2. AUDIO LOGIC: Bot joins and plays sound
            # Check if bot is already connected in this guild
            vc = discord.utils.get(bot.voice_clients, guild=member.guild)

            if not vc:
                # Fresh connection
                vc = await after.channel.connect()
            elif vc.channel != after.channel:
                # Move to the user if already in a different channel
                await vc.move_to(after.channel)
            
            # CRITICAL: Wait for the handshake to stabilize before playing
            # This is the 'Secret Sauce' to avoiding 4006 errors
            await asyncio.sleep(1.2) 
            
            # NEW WAY: Checks your actual Discord roles (more reliable for testing)
            rarity = "Common" # Default
            for role in member.roles:
                if role.name in ["Exotic", "Legendary", "Epic", "Rare", "Uncommon"]:
                    rarity = role.name
                    break
            print(f"✨ Identified {member.name} as {rarity}")
            
            # This calls your play_rarity_sound function we built earlier
            await play_rarity_sound(vc, rarity)
            
            # Wait for sound to finish
            while vc.is_playing():
                await asyncio.sleep(0.5)
            

        except discord.ClientException as e:
            print(f"⚠️ Voice Client busy: {e}")
        except Exception as e:
            print(f"🔊 Audio Logic Error: {e}")
        finally:
            # Release the lock after a short buffer
            await asyncio.sleep(2)
            processing_users.discard(member.id)

