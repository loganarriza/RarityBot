@tasks.loop(seconds=86400)  # Runs once every 24 hours
async def update_rarity_cache():
    await bot.wait_until_ready()
    global user_rarity_cache
    
    guild = bot.get_guild(GUILD_ID)
    if not guild: return

    # 1. Run the "Reverse Rarity" math
    scores = calculate_deviation_rarity() # Your new Alpha-distance function
    if not scores: return

    total = len(scores)
    new_cache = {}
    
    print(f"\n--- 📊 {discord.utils.utcnow().strftime('%H:%M:%S')} RANKING UPDATE ---")

    for i, (user_id, distance) in enumerate(scores):
        # YOU MUST DEFINE MEMBER INSIDE THE LOOP
        member = guild.get_member(int(user_id))
        if member:
            # --- NEW: AUTO-SYNC TO DATABASE ---
            # This ensures DB Browser always has the latest name
            cursor.execute("""
                INSERT INTO user_map (user_id, nickname) 
                VALUES (?, ?) 
                ON CONFLICT(user_id) DO UPDATE SET nickname=excluded.nickname
            """, (str(member.id), member.name))
            db.commit() # Save it immediately
        # 2. Determine Rarity via Percentile
        percentile = i / total
        if percentile < 0.02:    rarity = "Exotic"
        elif percentile < 0.10:  rarity = "Legendary"
        elif percentile < 0.25:  rarity = "Epic"
        elif percentile < 0.45:  rarity = "Rare"
        elif percentile < 0.70:  rarity = "Uncommon"
        else:                   rarity = "Common"

        new_cache[user_id] = rarity
        
        # 3. Handle Discord Role Assignment
        member = guild.get_member(int(user_id))
        if member and not member.bot:
            old_rarity = user_rarity_cache.get(user_id)
            
            # Only trigger an update/print if their rank actually CHANGED
            if old_rarity != rarity:
                target_role = discord.utils.get(guild.roles, name=rarity)
                all_rarity_names = ["Exotic", "Legendary", "Epic", "Rare", "Uncommon", "Common"]
                all_roles = [discord.utils.get(guild.roles, name=n) for n in all_rarity_names]
                
                if target_role:
                    await member.remove_roles(*[r for r in all_roles if r and r in member.roles])
                    await member.add_roles(target_role)
                    
                    # 4. THE LIVE PRINT: Show the "Alpha Distance"
                    # Score is rounded to 4 decimal places for cleanliness
                    print(f"✨ ROLE CHANGE: {member.name.ljust(15)} | {str(old_rarity).rjust(10)} -> {rarity.ljust(10)} | Dist: {distance:.4f}")

    user_rarity_cache = new_cache

@bot.event
@bot.event
async def on_ready():
    print(f'✅ Logged in as {bot.user}')
    
    guild = bot.get_guild(GUILD_ID)
    if not guild:
        print("❌ ERROR: Guild not found. Check your GUILD_ID in the .env file.")
        return

    # --- PHASE 1: NICKNAME SYNC ---
    # We do this first so the DB Browser has names immediately
    try:
        print("🔄 Phase 1: Syncing usernames to database...")
        await update_user_map() 
    except sqlite3.OperationalError as e:
        print(f"⚠️ Database busy during sync: {e}")

    # --- PHASE 2: GENESIS ROLE SWEEP ---
    # Moves people who have ZERO history in the DB to 'Unranked'
    print("🔍 Phase 2: Running Genesis Role Sweep...")
    
    # Get all IDs that have actually talked/joined VC
    cursor.execute("SELECT DISTINCT source FROM interactions")
    ranked_ids = {str(row[0]) for row in cursor.fetchall()}
    
    unranked_role = discord.utils.get(guild.roles, name="Unranked")
    rarity_names = ["Exotic", "Legendary", "Epic", "Rare", "Uncommon", "Common"]
    rarity_roles = [discord.utils.get(guild.roles, name=n) for n in rarity_names]

    if unranked_role:
        for member in guild.members:
            if member.bot: continue
            
            user_id = str(member.id)
            
            # If they aren't in the DB, they shouldn't have a rarity role yet
            if user_id not in ranked_ids:
                if unranked_role not in member.roles:
                    # Strip any accidental rarity roles
                    roles_to_remove = [r for r in rarity_roles if r and r in member.roles]
                    if roles_to_remove:
                        await member.remove_roles(*roles_to_remove)
                    
                    await member.add_roles(unranked_role)
                    print(f"⚪ {member.name} -> Set to Unranked")
    else:
        print("⚠️ Warning: 'Unranked' role not found in server settings.")

    # --- PHASE 3: START BACKGROUND TASKS ---
    # We wait 2 seconds to let the DB "breathe" before the loop starts
    await asyncio.sleep(2)
    if not update_rarity_cache.is_running():
        update_rarity_cache.start()
        print("🚀 Rarity background task started.")

    print("✨ Genesis Sweep and Sync Complete. Bot is fully functional.")
    
