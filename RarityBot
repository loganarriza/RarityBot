    author_id = str(message.author.id)
    target_id = "SERVER"
    
    if message.reference and message.reference.resolved:
        target_id = str(message.reference.resolved.author.id)
    
    # Updated to include 'MESSAGE' type
    cursor.execute("INSERT INTO interactions (source, target, type, weight) VALUES (?, ?, ?, ?)", 
                   (author_id, target_id, 'MESSAGE', 1.0))
    db.commit()
    await bot.process_commands(message)
    
@bot.command()
async def summon(ctx):
    """Command to bring the bot into your current VC."""
    if ctx.author.voice:
        channel = ctx.author.voice.channel
        await channel.connect()
        await ctx.send(f"👁️ The Rarity Engine has entered **{channel.name}**.")
    else:
        await ctx.send("Join a Voice Channel first!")

@bot.event
async def on_voice_state_update(member, before, after):
    """The 'Entry Frag' - Records the interaction and plays rarity sound."""
    if member.bot: return
    
    # 1. TRACKING LOGIC: Record the VC Join in the DB
    if before.channel is None and after.channel is not None:
        # Record this as a high-weight interaction
        cursor.execute("INSERT INTO interactions (source, target, type, weight) VALUES (?, ?, ?, ?)",
                       (str(member.id), str(after.channel.id), 'VC_JOIN', 5.0))
        db.commit()
        print(f"🔊 Recorded VC Join for {member.name}")

    # 2. AUDIO LOGIC: Play sound if the bot is in the channel
    if before.channel is None and after.channel is not None:
        vc_client = member.guild.voice_client
        if vc_client and vc_client.channel == after.channel:
            rarity = user_rarity_cache.get(str(member.id), "Common")
            sound_path = RARITY_SOUNDS.get(rarity)
            if sound_path and not vc_client.is_playing():
                vc_client.play(discord.FFmpegPCMAudio(sound_path))

