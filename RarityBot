# Global cache to keep VC joins fast (O(1) lookup)
user_rarity_cache = {}


@tasks.loop(seconds=30)
async def update_rarity_cache():
    global user_rarity_cache
    
    # 1. Define the Guild immediately
    # Replace the numbers below with your actual Server ID
    # 1. NEW: Wait until the bot is fully connected to Discord
    await bot.wait_until_ready()
    GUILD_ID = int(os.getenv('GUILD_ID'))
    guild = bot.get_guild(GUILD_ID)
    
    if not guild:
        print("⚠️ Could not find the guild. Check your GUILD_ID!")
        return

    scores = calculate_pagerank()
    if not scores: 
        return

    total = len(scores)
    new_cache = {}

    # 2. Define the roles list for cleanup
    all_rarity_names = ["Exotic", "Legendary", "Epic", "Rare", "Uncommon", "Common"]
    all_roles = [discord.utils.get(guild.roles, name=n) for n in all_rarity_names]
    # Filter out 'SERVER' from the score list before calculating percentiles
    human_scores = [s for s in scores if s[0] != "SERVER"]
    total = len(human_scores)

    for i, (user_id, score) in enumerate(human_scores):
        # Now 'i' correctly represents the rank among humans, and 'total' is the count of human users
        if user_id == "SERVER" or user_id == "UNKNOWN" or user_id == "269758345357819904":
            continue
        
        percentile = i / total
        
        if percentile < 0.02:    # Top 2%
            rarity = "Exotic"
        elif percentile < 0.10:  # Next 8%
            rarity = "Legendary"
        elif percentile < 0.25:  # Next 15%
            rarity = "Epic"
        elif percentile < 0.45:  # Next 20%
            rarity = "Rare"
        elif percentile < 0.70:  # Next 25%
            rarity = "Uncommon"
        else:                   # Bottom 30%
            rarity = "Common"
            
        new_cache[user_id] = rarity

        # --- LIVE ROLE ASSIGNMENT ---
        member = guild.get_member(int(user_id))
        if member:
            try:
                # Get the roles
                all_rarity_names = ["Exotic", "Legendary", "Epic", "Rare", "Uncommon", "Common"]
                all_roles = [discord.utils.get(guild.roles, name=n) for n in all_rarity_names]
                target_role = discord.utils.get(guild.roles, name=rarity)

                if target_role:
                    # Only remove/add if they don't already have the correct role
                    # This saves API calls and prevents 503s!
                    if target_role not in member.roles:
                        roles_to_remove = [r for r in all_roles if r and r in member.roles]
                        if roles_to_remove:
                            await member.remove_roles(*roles_to_remove)
                        await member.add_roles(target_role)
                        
            except discord.HTTPException as e:
                # This catches 503, 500, and 429 (rate limits)
                print(f"⚠️ Discord API is struggling (Status {e.status}). Skipping {member.name} for now.")
                continue
    
    user_rarity_cache = new_cache
    print("✅ Rarity cache updated via PageRank.")

@bot.event
async def on_ready():
    print(f'Logged in as {bot.user}')
    
    guild = bot.get_guild(GUILD_ID)
    if guild:
        # Define the rarity roles we care about
        rarity_names = ["Exotic", "Legendary", "Epic", "Rare", "Uncommon", "Common"]
        common_role = discord.utils.get(guild.roles, name="Common")
        
        if common_role:
            print("🛠️ Genesis Sweep: Checking for unranked users...")
            for member in guild.members:
                if member.bot: continue
                
                # Check if the member already has ANY of the rarity roles
                has_rarity = any(role.name in rarity_names for role in member.roles)
                
                # If they have no rarity role, they are a 'new' data point
                if not has_rarity:
                    await member.add_roles(common_role)
                    print(f"✅ Assigned Common to {member.name}")
    
    if not update_rarity_cache.is_running():
        update_rarity_cache.start()

