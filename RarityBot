# --- 3. THE MATH ENGINE (PAGERANK) ---
def calculate_pagerank():
    """Calculates the Principal Eigenvector of the social graph."""
    # Pull the last 7 days of data to keep rarities 'fresh'
    cursor.execute("""
        SELECT source, target, SUM(weight) 
        FROM interactions 
        WHERE timestamp > datetime('now', '-7 days') 
        GROUP BY source, target
    """)
    data = cursor.fetchall()
    
    if not data:
        return {}

    G = nx.DiGraph()
    for src, tgt, w in data:
        G.add_edge(src, tgt, weight=w)
    
    # This is the Eigen-solver. It returns a dict of {user_id: score}
    scores = nx.pagerank(G, weight='weight', alpha=ALPHA)
    return sorted(scores.items(), key=lambda x: x[1], reverse=True)

# --- 4. THE BOT LOGIC ---
intents = discord.Intents.all()
bot = commands.Bot(command_prefix="!", intents=intents)

# Global cache to keep VC joins fast (O(1) lookup)
user_rarity_cache = {}


@tasks.loop(seconds=30)
async def update_rarity_cache():
    global user_rarity_cache
    
    # 1. Define the Guild immediately
    # Replace the numbers below with your actual Server ID
    GUILD_ID = 123456789012345678  
    guild = bot.get_guild(GUILD_ID)
    
    if not guild:
        print("⚠️ Could not find the guild. Check your GUILD_ID!")
        return

    scores = calculate_pagerank()
    if not scores: 
        return

    total = len(scores)
    new_cache = {}

    # 2. Define the roles list for cleanup
    all_rarity_names = ["Exotic", "Legendary", "Epic", "Rare", "Uncommon", "Common"]
    all_roles = [discord.utils.get(guild.roles, name=n) for n in all_rarity_names]

    for i, (user_id, score) in enumerate(scores):
        percentile = i / total
        
        if percentile < 0.02:    # Top 2%
            rarity = "Exotic"
        elif percentile < 0.10:  # Next 8%
            rarity = "Legendary"
        elif percentile < 0.25:  # Next 15%
            rarity = "Epic"
        elif percentile < 0.45:  # Next 20%
            rarity = "Rare"
        elif percentile < 0.70:  # Next 25%
            rarity = "Uncommon"
        else:                   # Bottom 30%
            rarity = "Common"
            
        new_cache[user_id] = rarity

        # --- LIVE ROLE ASSIGNMENT ---
        member = guild.get_member(int(user_id))
        if member:
            # We fetch all possible rarity roles to ensure we clean up old ones
            all_rarity_names = ["Exotic", "Legendary", "Epic", "Rare", "Uncommon", "Common"]
            all_roles = [discord.utils.get(guild.roles, name=n) for n in all_rarity_names]
            
            # Find the specific role for the current rarity
            target_role = discord.utils.get(guild.roles, name=rarity)
            
            if target_role:
                # Remove any existing rarity roles the user has
                await member.remove_roles(*[r for r in all_roles if r and r in member.roles])
                # Add the new one
                await member.add_roles(target_role)
    
    user_rarity_cache = new_cache
    print("✅ Rarity cache updated via PageRank.")

@bot.event
async def on_ready():
    print(f'Logged in as {bot.user.name}')
    update_rarity_cache.start()

@bot.event
