def calculate_deviation_rarity():
    # We use the Exponential Decay formula directly in the SQL
    # 0.0077 is the lambda for a ~90 day half-life
    decay_query = """
    SELECT source, 
           SUM(weight * exp(-0.0077 * (julianday('now') - julianday(timestamp)))) as decayed_weight
    FROM interactions 
    WHERE timestamp > datetime('now', '-365 days') -- Ignore truly ancient data
    GROUP BY source
    """
    cursor.execute(decay_query)
    data = cursor.fetchall()
    
    if not data: return []

    human_data = [row for row in data if row[0] != "SERVER"]
    if not human_data: return []
    
    # Alpha is the person with the highest DECAYED weight (most active recently)
    alpha_id, alpha_score = max(human_data, key=lambda x: x[1])

    rarity_scores = []
    for user_id, weight in human_data:
        # Distance from the active 'Alpha'
        distance = (alpha_score - weight) / alpha_score
        rarity_scores.append((user_id, distance))

    # Sort: Highest distance (most decayed/inactive) = Exotic
    rarity_scores.sort(key=lambda x: x[1], reverse=True)
    return rarity_scores

